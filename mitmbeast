#!/usr/bin/env bash
# mitmbeast — convenience wrapper.
#
# Usage:
#   ./mitmbeast              # opens the TUI
#   ./mitmbeast up -k        # forwards to the click CLI (any subcommand)
#   ./mitmbeast tui          # explicit; same as no args
#
# The wrapper bootstraps the Python venv via `uv` on first run, then
# execs the entry point. Most TUI actions need root for the system
# operations they trigger; if the wrapper isn't running as root,
# operations that need it will surface a clear error.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [ ! -x ".venv/bin/mitmbeast" ]; then
  echo "First run — bootstrapping the Python venv with uv..." >&2
  if ! command -v uv >/dev/null 2>&1; then
    echo "Error: uv is not installed." >&2
    echo "Install it with:  curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
    exit 1
  fi
  uv sync --extra dev >&2
fi

exec .venv/bin/mitmbeast "$@"
